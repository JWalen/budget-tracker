# ==========================================
# CRITICAL SECURITY CONFIGURATION
# ==========================================
# IMPORTANT: Generate secure random values for all secrets in production!
# Use these commands to generate secure values:
# JWT_SECRET: openssl rand -hex 64
# ENCRYPTION_KEY: openssl rand -hex 32
# SESSION_SECRET: openssl rand -hex 32

# Database Configuration
DB_USER=budget_user
DB_PASSWORD=change_me_in_production_use_strong_password
DB_NAME=budget_db
DB_PORT=5433

# JWT Configuration - CRITICAL: Change these in production!
JWT_SECRET=change_this_to_a_random_64_character_string_use_openssl_rand_hex_64
JWT_REFRESH_SECRET=change_this_to_another_random_64_character_string_use_openssl_rand_hex_64

# Encryption for sensitive data (MFA secrets, API keys, etc.)
ENCRYPTION_KEY=change_this_32_byte_hex_key_use_openssl_rand_hex_32
MFA_ENCRYPTION_KEY=change_this_mfa_encryption_key_use_openssl_rand_hex_32

# Application Configuration
NODE_ENV=development
BACKEND_PORT=5050
FRONTEND_PORT=3456
FRONTEND_URL=http://localhost:3456
API_URL=http://localhost:5050

# Session Configuration
SESSION_SECRET=change_this_session_secret_use_openssl_rand_hex_32
COOKIE_SECURE=false  # Set to true when using HTTPS in production

# Email Configuration
EMAIL_PROVIDER=none  # Options: none, sendgrid, gmail, smtp, resend
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Budget Tracker

# SendGrid (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# Gmail (if EMAIL_PROVIDER=gmail)
SMTP_USER=
SMTP_PASS=

# Custom SMTP (if EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false

# Resend (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=

# AI Configuration
# The AI assistant uses a hosted provider (Anthropic Claude or OpenAI).
# Provider, model, and API keys are configured in-app under
# Admin → AI Configuration and stored encrypted in the database — no env vars
# needed here. (Keys are encrypted with ENCRYPTION_KEY, set above.)

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # requests per window
HTTPS_ONLY=false  # Set to true in production when using HTTPS
CSRF_ENABLED=true
HELMET_ENABLED=true

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3456,http://localhost:3000

# Feature Flags
ENABLE_MFA=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_FAMILY_MODE=true
ENABLE_AI_ASSISTANT=true

# Logging Configuration
LOG_LEVEL=info  # Options: debug, info, warn, error
LOG_FILE=./logs/app.log
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# Backup Configuration
BACKUP_ENCRYPTION_KEY=change_this_backup_key_use_openssl_rand_hex_32
AUTO_BACKUP_ENABLED=false
AUTO_BACKUP_INTERVAL=daily  # Options: hourly, daily, weekly, monthly
AUTO_BACKUP_RETENTION_DAYS=30

# MFA Configuration
MFA_ISSUER=Budget Tracker

# Production Checklist
# 1. Generate all random secrets using openssl rand -hex [length]
# 2. Use strong database password
# 3. Set NODE_ENV=production
# 4. Set HTTPS_ONLY=true and COOKIE_SECURE=true when using HTTPS
# 5. Configure proper email provider
# 6. Set appropriate ALLOWED_ORIGINS for your domain
# 7. Review and adjust rate limiting values
# 8. Enable AUTO_BACKUP_ENABLED with encryption
# 9. Ensure LOG_FILE path is writable
# 10. Test MFA functionality before enabling